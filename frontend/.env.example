# Optional. Leave unset to use the default:
#   - dev: Vite proxies "/api" to http://localhost:8002
#   - prod: SPA and API share the same origin on Vercel ("/api")
# Set this only to point the frontend at a different backend host.
# VITE_API_URL=https://your-app.vercel.app/api

# Optional. Community/support link (a Discord invite) shown only in the
# authenticated dashboard nav. Leave unset to hide the "Support" link entirely.
# VITE_DISCORD_URL=https://discord.gg/your-invite
